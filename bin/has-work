#!/usr/bin/env python3
"""Cheap pre-check (NO LLM): is there any NEW mail, a pending board Action, or a stale-awaiting card?
Exit 0 = there is work (run the agent); exit 1 = nothing to do (skip the expensive claude run).

Relies on `email` / `board` being on PATH and the Notion token + proxy in env (set by the runner).
Iterates every configured account.
"""
import json
import os
import subprocess
import sys

sys.path.insert(0, os.path.join(os.environ.get("INBOARD_HOME") or
                                os.path.dirname(os.path.dirname(os.path.abspath(__file__))), "lib"))
import ibconfig as C  # noqa: E402

HOME = C.home()
EMAIL = os.path.join(HOME, "bin", "email")
BOARD = os.path.join(HOME, "bin", "board")
state = os.environ.get("INBOARD_STATE") or os.path.join(HOME, "state")
proc_path = os.path.join(state, "processed.json")
try:
    processed = set(json.load(open(proc_path)).keys())
except Exception:
    processed = set()


def triage(account_id):
    try:
        out = subprocess.run([EMAIL, account_id, "gmail", "+triage", "--query", "in:inbox newer_than:2d",
                              "--max", "100", "--format", "json"], capture_output=True, text=True, timeout=60).stdout
        msgs = json.loads(out).get("messages", [])
        return [m["id"] for m in msgs if m.get("id")]
    except Exception as e:
        sys.stderr.write(f"triage {account_id} err: {e}\n")
        return []


ids = set()
for acc in C.accounts():
    ids |= set(triage(acc.get("id")))
new = ids - processed


def board_count(args):
    try:
        return len(json.loads(subprocess.run([BOARD] + args, capture_output=True, text=True, timeout=30).stdout))
    except Exception as e:
        sys.stderr.write(f"{' '.join(args)} err: {e}\n")
        return 0


pending = board_count(["pending"])
stale = board_count(["stale-awaiting", "--days", str(C.get("schedule.stale_awaiting_days", 3))])

print(f"new={len(new)} pending={pending} stale={stale}")
sys.exit(0 if (new or pending or stale) else 1)
